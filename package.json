    "telegraf": "^4.16.3",
    "zod": "^3.23.8",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "@types/pg": "^8.11.10",
    "@types/node-cron": "^3.0.11",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=18.17.0"
