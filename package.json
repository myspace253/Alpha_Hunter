  "description": "AI-powered Solana token scanner and alpha scoring bot with Telegram alerts",
  "main": "dist/index.js",
  "type": "commonjs",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
