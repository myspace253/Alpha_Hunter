########################################
# Solana AI Alpha Hunter — Environment
# Copy this file to ".env" and fill in real values.
# Never commit your real .env file.
########################################

### App ###
NODE_ENV=development
LOG_LEVEL=info
# How often (in seconds) the scanner polls for new tokens / signal updates
SCAN_INTERVAL_SECONDS=30

### Telegram ###
# Create a bot via https://t.me/BotFather and paste the token here
TELEGRAM_BOT_TOKEN=123456789:AAA-your-telegram-bot-token
# Comma-separated chat/channel IDs that should receive automatic alerts
TELEGRAM_ALERT_CHAT_IDS=

### Solana RPC / Indexer providers ###
# At least one RPC provider is required. Helius is recommended for webhooks + enhanced tx parsing.
HELIUS_API_KEY=
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_API_KEY
# Optional secondary/backup RPC providers
QUICKNODE_RPC_URL=
ALCHEMY_RPC_URL=
SHYFT_API_KEY=
# Max requests/second to Helius's enhanced-transactions REST API (wallet buy/sell detection).
# Lower this if you're still seeing 429s from Helius on a free/dev-tier key.
HELIUS_RATE_LIMIT_PER_SEC=2

### Market data providers ###
# DexScreener has a free public API (no key required) used as the default data source
DEXSCREENER_BASE_URL=https://api.dexscreener.com
# Birdeye requires a paid/free-tier API key: https://birdeye.so
BIRDEYE_API_KEY=
BIRDEYE_BASE_URL=https://public-api.birdeye.so
# Max requests/second to Birdeye. Free tier is commonly capped at 1/sec — check the
# X-RateLimit-Limit header on your responses and adjust to match your actual plan.
BIRDEYE_RATE_LIMIT_PER_SEC=1
# Jupiter price/token API (no key required for basic usage)
JUPITER_BASE_URL=https://lite-api.jup.ag

### Social signal providers (optional, used by Social Monitor service) ###
TWITTER_BEARER_TOKEN=
LUNARCRUSH_API_KEY=

### News providers (optional) ###
CRYPTOPANIC_API_KEY=

### AI / LLM ###
# Used for Explainable AI answers ("why is this token good?") and the /ask agent via the LLM
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Alternative: point at an Anthropic-compatible or self-hosted LLM gateway instead
LLM_PROVIDER=openai
# Base URL for the OpenAI-compatible chat completions API. Defaults to OpenAI directly.
# To route through ZenMux (or any other OpenAI-compatible proxy/router) instead, set:
#   AI_BASE_URL=https://zenmux.ai/api/v1
# OPENAI_API_KEY is still sent as the bearer token — use your ZenMux (or router) key here.
AI_BASE_URL=https://api.openai.com/v1
# Timeout for LLM requests, in milliseconds. Routers/proxies to slower or queued models often
# need more headroom than a direct OpenAI call — 600000 = 10 minutes.
API_TIMEOUT_MS=600000

### Database ###
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=alpha_hunter
POSTGRES_USER=alpha_hunter
POSTGRES_PASSWORD=change_me
DATABASE_URL=postgresql://alpha_hunter:change_me@localhost:5432/alpha_hunter

### Redis (cache, rate-limit buckets, dedupe of alerts) ###
REDIS_URL=redis://localhost:6379

### Scoring thresholds ###
# Minimum AI score (0-100) required before a token triggers a Telegram alert
MIN_ALERT_SCORE=70
# Maximum acceptable risk score (0-100, higher = riskier) for auto-alerts
MAX_ALERT_RISK=40
